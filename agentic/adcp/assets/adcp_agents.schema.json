{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thenexusengine.com/schemas/adcp_agents.v1.json",
  "title": "TNE Catalyst adcp_agents.json",
  "description": "Schema for the AdCP (Ad Context Protocol) agent registry. Peer to agents.json; AdCP is capability-oriented (get_signals / get_products / activate_signal / create_media_buy) over MCP, while ARTF agents.json is mutation-oriented over gRPC.",
  "type": "object",
  "required": ["version", "seller_id", "seller_domain", "agents"],
  "additionalProperties": true,
  "properties": {
    "$schema":       {"type": "string"},
    "version":       {"type": "string", "enum": ["1.0"]},
    "seller_id":     {"type": "string", "minLength": 1, "maxLength": 64},
    "seller_domain": {"type": "string", "format": "hostname"},
    "contact":       {"type": "string"},
    "updated_at":    {"type": "string", "format": "date-time"},
    "agents": {
      "type": "array",
      "items": {"$ref": "#/definitions/agent"}
    }
  },
  "definitions": {
    "agent": {
      "type": "object",
      "required": ["id", "role", "endpoints", "lifecycles", "capabilities"],
      "additionalProperties": true,
      "properties": {
        "id":           {"type": "string", "minLength": 1, "maxLength": 253, "pattern": "^[a-zA-Z0-9._-]+$"},
        "name":         {"type": "string"},
        "role":         {"type": "string", "enum": ["signals", "sales", "creative", "performance", "composite"]},
        "vendor":       {"type": "string"},
        "registry_ref": {"type": "string"},
        "priority":     {"type": "integer", "minimum": 0, "maximum": 1000},
        "tmax_ms":      {"type": "integer", "minimum": 1, "maximum": 500},
        "essential":    {"type": "boolean"},
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["transport", "url", "auth"],
            "additionalProperties": true,
            "properties": {
              "transport": {"type": "string", "enum": ["mcp", "https", "http"]},
              "url":       {"type": "string"},
              "auth":      {"type": "string", "enum": ["api_key_header", "mtls", "oauth2", "none"]}
            }
          }
        },
        "lifecycles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "PRE_AUCTION_SIGNALS",
              "PRE_AUCTION_PRODUCTS",
              "POST_AUCTION_REPORTING"
            ]
          }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "get_signals",
              "get_products",
              "list_creative_formats",
              "activate_signal",
              "create_media_buy",
              "update_performance_index",
              "get_media_buy_delivery"
            ]
          }
        },
        "requires": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "tcf_purposes": {"type": "array", "items": {"type": "integer"}},
            "precise_geo":  {"type": "boolean"}
          }
        },
        "data_processing": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "categories":     {"type": "array", "items": {"type": "string"}},
            "retention_days": {"type": "integer", "minimum": 0}
          }
        }
      }
    }
  }
}
